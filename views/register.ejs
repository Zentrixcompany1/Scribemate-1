<%- include('layout', { user: null, body: `
  <section class="panel">
    <h1>Teacher Registration</h1>
    <p class="intro">Create your teacher account to manage students, upload exams, and review submissions.</p>
    <% if (error) { %>
      <div class="alert alert-error" role="alert"><%= error %></div>
    <% } %>
    <% if (message) { %>
      <div class="alert alert-success" role="status"><%= message %></div>
    <% } %>
    <form action="/register" method="post" class="form-grid" aria-label="Teacher registration form">
      <label for="name">Full name</label>
      <input id="name" name="name" type="text" required />

      <label for="email">Email address</label>
      <input id="email" name="email" type="email" required />

      <label for="password">Password</label>
      <input id="password" name="password" type="password" autocomplete="new-password" required />

      <button type="submit" class="button button-primary">Register as teacher</button>
    </form>
    <div class="help-text">
      <p>After registering, you can add student accounts from your dashboard.</p>
    </div>
  </section>
` }) %>
