<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Scribemate</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <div class="page-shell">
      <header class="site-header" role="banner">
        <div class="brand">
          <a href="/" class="brand-link">Scribemate</a>
          <span class="brand-tag">Accessible exam platform</span>
        </div>
        <% if (user) { %>
        <nav aria-label="Main navigation" class="site-nav">
          <a href="/">Home</a>
          <% if (user.role === 'teacher') { %>
          <a href="/teacher/students">Students</a>
          <a href="/teacher/exams">Exams</a>
          <% } else { %>
          <a href="/student">Exams</a>
          <% } %>
          <a href="/logout">Logout</a>
        </nav>
        <% } %>
      </header>

      <main class="content" role="main">
        <%- body %>
      </main>

      <footer class="site-footer">
        <p>Built for accessible exam experiences for blind and impaired students.</p>
      </footer>
    </div>
  </body>
</html>
