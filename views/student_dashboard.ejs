<%- include('layout', { user: student, body: `
  <section class="panel">
    <h1>Hello, <%= student.name %></h1>
    <p class="intro">Your assigned exams appear below. Submit your answers securely and teachers can download your scripts.</p>
  </section>

  <section class="panel">
    <h2>Assigned exams</h2>
    <% if (exams.length === 0) { %>
      <p>No exams are assigned to you yet. Check back later or contact your teacher.</p>
    <% } else { %>
      <table class="data-table" aria-label="Assigned exams">
        <thead>
          <tr>
            <th>Exam</th>
            <th>Status</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% exams.forEach(function(exam) { %>
            <% const submission = submissions.find((item) => item.examId === exam.id); %>
            <tr>
              <td><%= exam.title %></td>
              <td><%= submission ? 'Submitted' : 'Pending' %></td>
              <td><a href="/student/exams/<%= exam.id %>" class="button button-tertiary">Open</a></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </section>
` }) %>
