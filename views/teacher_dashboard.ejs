<%- include('layout', { user: teacher, body: `
  <section class="panel">
    <h1>Welcome, <%= teacher.name %></h1>
    <p class="intro">Use the dashboard to manage student accounts, publish exams, and monitor answer submissions.</p>
    <div class="grid cards">
      <div class="card">
        <h2>Students</h2>
        <p><strong><%= students.length %></strong> active student(s)</p>
        <a href="/teacher/students" class="button button-secondary">Manage students</a>
      </div>
      <div class="card">
        <h2>Exams</h2>
        <p><strong><%= exams.length %></strong> exam(s) created</p>
        <a href="/teacher/exams" class="button button-secondary">Manage exams</a>
      </div>
      <div class="card">
        <h2>Submissions</h2>
        <p><strong><%= submissions.length %></strong> submission(s) received</p>
        <a href="/teacher/exams" class="button button-secondary">Review submissions</a>
      </div>
    </div>
  </section>

  <section class="panel">
    <h2>Latest answers</h2>
    <% if (submissions.length === 0) { %>
      <p>No answers submitted yet. Students will submit exam answers from their dashboard.</p>
    <% } else { %>
      <table class="data-table" aria-label="Recent submissions">
        <thead>
          <tr>
            <th>Student</th>
            <th>Exam</th>
            <th>Submitted</th>
            <th>Download</th>
          </tr>
        </thead>
        <tbody>
          <% submissions.slice(-6).reverse().forEach(function(submission) { %>
            <% const student = findUserById(submission.studentId); const exam = exams.find((item) => item.id === submission.examId); %>
            <tr>
              <td><%= student ? student.name : 'Unknown' %></td>
              <td><%= exam ? exam.title : 'Unknown exam' %></td>
              <td><%= new Date(submission.submittedAt).toLocaleString() %></td>
              <td><a href="/download/<%= submission.id %>" class="button button-tertiary">Download</a></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </section>
` }) %>
