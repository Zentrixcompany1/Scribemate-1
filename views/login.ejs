<%- include('layout', { user: null, body: `
  <section class="panel">
    <h1>Teacher Login</h1>
    <p class="intro">Sign in to manage students, upload exams, and review submissions.</p>
    <% if (error) { %>
      <div class="alert alert-error" role="alert"><%= error %></div>
    <% } %>
    <form action="/login" method="post" class="form-grid" aria-label="Login form">
      <label for="email">Email address</label>
      <input id="email" name="email" type="email" autocomplete="username" required />

      <label for="password">Password</label>
      <input id="password" name="password" type="password" autocomplete="current-password" required />

      <button type="submit" class="button button-primary">Sign in</button>
    </form>
    <div class="help-text">
      <p>Need a teacher account? <a href="/register">Register here</a>.</p>
    </div>
  </section>
` }) %>
