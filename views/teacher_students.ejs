<%- include('layout', { user: teacher, body: `
  <section class="panel">
    <h1>Manage Students</h1>
    <p class="intro">Create student accounts and assign them to your exams automatically.</p>
    <% if (error) { %>
      <div class="alert alert-error" role="alert"><%= error %></div>
    <% } %>
    <% if (message) { %>
      <div class="alert alert-success" role="status"><%= message %></div>
    <% } %>
    <form action="/teacher/students" method="post" class="form-grid" aria-label="Add student form">
      <label for="name">Student name</label>
      <input id="name" name="name" type="text" required />

      <label for="email">Student email</label>
      <input id="email" name="email" type="email" required />

      <label for="password">Temporary password</label>
      <input id="password" name="password" type="password" autocomplete="new-password" required />

      <button type="submit" class="button button-primary">Create student</button>
    </form>
  </section>

  <section class="panel">
    <h2>Your students</h2>
    <% if (students.length === 0) { %>
      <p>No students added yet. Use the form above to add a student account.</p>
    <% } else { %>
      <table class="data-table" aria-label="Student list">
        <thead>
          <tr>
            <th>Name</th>
            <th>Email</th>
          </tr>
        </thead>
        <tbody>
          <% students.forEach(function(student) { %>
            <tr>
              <td><%= student.name %></td>
              <td><%= student.email %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </section>
` }) %>
