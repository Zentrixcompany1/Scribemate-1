<%- include('layout', { user: teacher, body: `
  <section class="panel">
    <h1>Submissions for <%= exam.title %></h1>
    <% if (submissions.length === 0) { %>
      <p>No answers have been submitted for this exam yet.</p>
    <% } else { %>
      <table class="data-table" aria-label="Teacher submission list">
        <thead>
          <tr>
            <th>Student</th>
            <th>Answer preview</th>
            <th>Submitted</th>
            <th>Download</th>
          </tr>
        </thead>
        <tbody>
          <% submissions.forEach(function(submission) { %>
            <tr>
              <td><%= submission.student ? submission.student.name : 'Unknown' %></td>
              <td><%= submission.answer.slice(0, 100) %><%= submission.answer.length > 100 ? '…' : '' %></td>
              <td><%= new Date(submission.submittedAt).toLocaleString() %></td>
              <td><a href="/download/<%= submission.id %>" class="button button-tertiary">Download</a></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </section>
` }) %>
