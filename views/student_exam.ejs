<%- include('layout', { user: student, body: `
  <section class="panel">
    <h1>Exam: <%= exam.title %></h1>
    <p class="intro"><%= exam.description || 'Please answer the questions below in the text area provided.' %></p>
    <ol class="question-list">
      <% exam.questions.forEach(function(question) { %>
        <li><%= question %></li>
      <% }) %>
    </ol>
    <% if (error) { %>
      <div class="alert alert-error" role="alert"><%= error %></div>
    <% } %>
    <form action="/student/exams/<%= exam.id %>" method="post" class="form-grid" aria-label="Exam answer form">
      <label for="answer">Your answer script</label>
      <textarea id="answer" name="answer" rows="12" required><%= submission ? submission.answer : '' %></textarea>
      <button type="submit" class="button button-primary"><%= submission ? 'Update submission' : 'Submit answer' %></button>
    </form>
    <% if (submission) { %>
      <div class="info-box">
        You submitted this exam on <strong><%= new Date(submission.submittedAt).toLocaleString() %></strong>. You may update it if needed.
      </div>
    <% } %>
  </section>
` }) %>
